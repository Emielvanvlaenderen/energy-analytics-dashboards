{
  "name": "portfolio-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup:env": "node ../scripts/setup-env-local.mjs",
    "dev:with-api": "concurrently -k \"vite\" \"node --env-file=.env.local server/index.mjs\"",
    "dev:server": "node --env-file=.env.local server/index.mjs",
    "test:continue": "node server/test-continue.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "refresh:market-data": "node --env-file=.env.local server/jobs/refreshMarketData.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "express": "^5.2.1",
    "luxon": "^3.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
