# --- Frontend (Netlify or Vite) ---
VITE_API_BASE_URL=https://YOUR-API.onrender.com
# Copy to web/.env.local (or run: cd web && npm run setup:env)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- API server (Render) ---
PORT=3001
NODE_ENV=production
DATA_ROOT=/var/data
CORS_ORIGINS=https://YOUR-SITE.netlify.app,http://localhost:5173
PYTHON=python3

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Daily market-data refresh (GitHub Actions → Render cron endpoint)
# CRON_SECRET=long-random-string

# Fallback live fetch when Supabase cache is empty (optimisation run only)
# EMBER_HOURLY_ZIP_URL=https://files.ember-energy.org/public-downloads/price/outputs/european_wholesale_electricity_price_data_hourly.zip
# EMBER_CACHE_TTL_MS=21600000
# DAY_AHEAD_DISABLE_API=true
# PV_LIVE_DISABLE_API=true

# Local dev only: keep using repo projects/ folders instead of guest workspaces
# USE_LEGACY_PROJECT_DIRS=true
